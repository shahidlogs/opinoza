# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/opinoza

# ── Clerk Authentication ───────────────────────────────────────────────────────
# Server-side secret key (from Clerk dashboard → API Keys)
CLERK_SECRET_KEY=sk_live_...

# Client-side publishable key (from Clerk dashboard → API Keys)
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# Proxy URL for Clerk in production (your domain, e.g. https://opinoza.com)
VITE_CLERK_PROXY_URL=https://opinoza.com

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
APP_BASE_URL=https://opinoza.com
NODE_ENV=production

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-long-random-string

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-password

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
