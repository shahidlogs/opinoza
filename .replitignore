# The format of this file is identical to `.dockerignore`.
# It is used to reduce the size of deployed images to make the process of publishing faster.

# ── Large backup archives (primary cause of HTTP 413) ────────────────────────
*.zip
*.tar
*.tar.gz
*.tar.bz2
*.tgz
*.rar
*.7z

# ── Non-essential build output ────────────────────────────────────────────────
artifacts/mockup-sandbox/dist

# ── Vite / build caches ───────────────────────────────────────────────────────
**/.vite
**/.turbo
**/.parcel-cache

# ── Dev / agent-only files ────────────────────────────────────────────────────
.local
.cache
**/.cache
attached_assets
.agents

# ── Git internals ─────────────────────────────────────────────────────────────
.git

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS / editor clutter ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode
.idea
