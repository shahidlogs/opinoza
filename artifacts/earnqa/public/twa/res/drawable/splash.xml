<?xml version="1.0" encoding="utf-8"?>
<!--
  Pre-Android-12 splash drawable.
  Drop into: app/src/main/res/drawable/splash.xml

  Uses a layer list to center the coin icon on the brand background color.
  The ic_launcher icon is drawn centered with a 1/4-screen margin on each side.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background fill: Opinoza warm off-white -->
    <item>
        <color android:color="@color/splash_background"/>
    </item>

    <!-- Coin icon centered, with comfortable breathing room (25% inset each side) -->
    <item
        android:gravity="center"
        android:drawable="@mipmap/ic_launcher"
        android:width="160dp"
        android:height="160dp"/>

</layer-list>
